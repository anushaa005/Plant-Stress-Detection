    {
      "cell_type": "code",
      "source": [
        "import os\n",
        "import cv2\n",
        "\n",
        "# The path provided by kagglehub + the internal folders shown in your print output\n",
        "BASE_PATH = \"/root/.cache/kagglehub/datasets/adilmubashirchaudhry/plant-village-dataset/versions/1\"\n",
        "INPUT_DIR = os.path.join(BASE_PATH, \"PlantVillageDataset\", \"PlantVillage\")\n",
        "\n",
        "OUTPUT_DIR = \"/content/patch_dataset\"\n",
        "\n",
        "PATCH_SIZE = 112\n",
        "STRIDE = 112\n",
        "\n",
        "# Check if path exists before running\n",
        "if not os.path.exists(INPUT_DIR):\n",
        "    print(f\"Error: Path not found! Check: {INPUT_DIR}\")\n",
        "else:\n",
        "    classes = os.listdir(INPUT_DIR)\n",
        "    print(f\"Found {len(classes)} classes. Starting patching...\")\n",
        "\n",
        "    for cls in classes:\n",
        "        class_path = os.path.join(INPUT_DIR, cls)\n",
        "\n",
        "        # Skip if it's a hidden file like .DS_Store\n",
        "        if not os.path.isdir(class_path):\n",
        "            continue\n",
        "\n",
        "        for img_name in os.listdir(class_path):\n",
        "            img_path = os.path.join(class_path, img_name)\n",
        "            img = cv2.imread(img_path)\n",
        "\n",
        "            if img is None:\n",
        "                continue\n",
        "\n",
        "            h, w, _ = img.shape\n",
        "\n",
        "            for y in range(0, h - PATCH_SIZE + 1, STRIDE):\n",
        "                for x in range(0, w - PATCH_SIZE + 1, STRIDE):\n",
        "\n",
        "                    patch = img[y:y+PATCH_SIZE, x:x+PATCH_SIZE]\n",
        "\n",
        "                    # Skip useless patches\n",
        "                    if patch.mean() < 20:\n",
        "                        continue\n",
        "\n",
        "                    save_dir = os.path.join(OUTPUT_DIR, \"train\", cls)\n",
        "                    os.makedirs(save_dir, exist_ok=True)\n",
        "\n",
        "                    filename = f\"{img_name}_{x}_{y}.jpg\"\n",
        "                    cv2.imwrite(os.path.join(save_dir, filename), patch)\n",
        "    print(\"Patching complete!\")"
      ],
